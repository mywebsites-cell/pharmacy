# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmacy_licenses
DB_USER=postgres
DB_PASSWORD=YOUR_POSTGRES_PASSWORD

# JWT secrets — use long random strings in production
JWT_SECRET=change_me_long_random_string
JWT_REFRESH_SECRET=change_me_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# License token signing key
LICENSE_SECRET=change_me_license_signing_key

# Server config
PORT=9000
NODE_ENV=production

# CORS allowed origins (comma separated)
ALLOWED_ORIGINS=https://yourdomain.com

# Trial period (days)
TRIAL_DAYS=14

# Admin email (auto-created at startup)
ADMIN_EMAIL=admin@pharmacypro.com
ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
